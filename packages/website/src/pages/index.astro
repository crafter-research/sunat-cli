---
const features = [
	{
		title: "RHE Emission",
		desc: "Emit Recibos por Honorarios in batch. 12 months in one command.",
		code: "sunat-cli rhe emit --batch ./data.csv --dry-run",
	},
	{
		title: "F616 Declaration",
		desc: "Monthly 4ta categoria declarations. Input masks cracked via CDP.",
		code: 'sunat-cli f616 declare --json \'{"periodo":"03/2025"}\'',
	},
	{
		title: "Schema Introspection",
		desc: "Agents self-serve field definitions at runtime. Zero docs overhead.",
		code: "sunat-cli schema rhe --output json",
	},
	{
		title: "OAuth2 Verification",
		desc: "Verify emissions via SUNAT REST API. Token management built-in.",
		code: "sunat-cli api token --output json",
	},
];

const principles = [
	"--json payloads over flags",
	"--dry-run for all mutations",
	"--output json by default",
	"Schema introspection at runtime",
	"Input hardening against hallucinations",
	"SKILL.md per agentskills.io spec",
];

const stats = [
	{ value: "0", label: "CAPTCHAs needed" },
	{ value: "19", label: "RHEs in one batch" },
	{ value: "3", label: "Portals reverse-engineered" },
	{ value: "1h", label: "OAuth2 token TTL" },
];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>sunat-cli — Agent-First Tax Automation for Peru</title>
		<meta name="description" content="Agent-first CLI for SUNAT tax automation. Emit RHE, declare F616, verify via API. Built for AI agents. Open source by Crafter Station." />
		<meta property="og:title" content="sunat-cli — Agent-First Tax Automation" />
		<meta property="og:description" content="Automate SUNAT taxes: RHE, F616, OAuth2 API. Built for AI agents as primary consumers." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://sunat-cli.crafter.ing" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
		<style>
			* { margin: 0; padding: 0; box-sizing: border-box; }
			html { scroll-behavior: smooth; }

			:root {
				--sunat-blue: #1A3567;
				--sunat-blue-light: #2B4A8A;
				--sunat-red: #C41E3A;
				--sunat-red-hover: #A8182F;
				--bg-white: #FFFFFF;
				--bg-gray: #F5F5F5;
				--bg-dark: #0F172A;
				--border: #D1D5DB;
				--text-primary: #1A1A1A;
				--text-secondary: #4B5563;
				--text-muted: #9CA3AF;
			}

			body {
				font-family: 'Inter', system-ui, sans-serif;
				font-size: 15px;
				line-height: 1.6;
				color: var(--text-primary);
				background: var(--bg-white);
				-webkit-font-smoothing: antialiased;
			}

			.mono { font-family: 'JetBrains Mono', monospace; }

			.container {
				max-width: 1080px;
				margin: 0 auto;
				padding: 0 24px;
			}

			/* Nav */
			nav {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				z-index: 100;
				background: rgba(255,255,255,0.85);
				backdrop-filter: blur(12px);
				border-bottom: 1px solid var(--border);
			}
			.nav-inner {
				max-width: 1080px;
				margin: 0 auto;
				padding: 0 24px;
				height: 56px;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}
			.nav-brand {
				font-weight: 700;
				font-size: 15px;
				color: var(--sunat-blue);
				text-decoration: none;
				display: flex;
				align-items: center;
				gap: 6px;
			}
			.nav-brand span { color: var(--sunat-red); }
			.nav-links { display: flex; gap: 24px; align-items: center; }
			.nav-links a {
				color: var(--text-secondary);
				text-decoration: none;
				font-size: 13px;
				font-weight: 500;
				transition: color 150ms;
			}
			.nav-links a:hover { color: var(--text-primary); }
			.nav-cta {
				background: var(--sunat-blue) !important;
				color: white !important;
				padding: 6px 16px;
				border-radius: 6px;
				font-size: 13px !important;
			}
			.nav-cta:hover { background: var(--sunat-blue-light) !important; }

			/* Hero */
			.hero {
				padding: 140px 24px 80px;
				text-align: center;
				background: var(--bg-gray);
				border-bottom: 1px solid var(--border);
			}
			.hero-badge {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				padding: 4px 12px;
				background: white;
				border: 1px solid var(--border);
				border-radius: 999px;
				font-size: 12px;
				color: var(--text-secondary);
				margin-bottom: 24px;
			}
			.hero-badge .dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--sunat-red);
			}
			.hero h1 {
				font-size: clamp(32px, 5vw, 52px);
				font-weight: 700;
				line-height: 1.1;
				letter-spacing: -0.03em;
				color: var(--sunat-blue);
				margin-bottom: 16px;
			}
			.hero h1 .accent { color: var(--sunat-red); }
			.hero p {
				font-size: 17px;
				color: var(--text-secondary);
				max-width: 520px;
				margin: 0 auto 32px;
				font-weight: 400;
				line-height: 1.7;
			}
			.hero-actions {
				display: flex;
				gap: 12px;
				justify-content: center;
				flex-wrap: wrap;
				margin-bottom: 32px;
			}
			.btn {
				display: inline-flex;
				align-items: center;
				padding: 10px 24px;
				border-radius: 8px;
				font-size: 14px;
				font-weight: 600;
				text-decoration: none;
				transition: all 150ms;
				border: none;
				cursor: pointer;
			}
			.btn-primary {
				background: var(--sunat-red);
				color: white;
			}
			.btn-primary:hover { background: var(--sunat-red-hover); }
			.btn-outline {
				background: white;
				color: var(--text-primary);
				border: 1px solid var(--border);
			}
			.btn-outline:hover { border-color: var(--text-secondary); }

			.install-box {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 10px 20px;
				background: var(--bg-dark);
				border-radius: 8px;
				color: var(--text-muted);
				font-size: 13px;
			}
			.install-box code { color: #E2E8F0; }
			.install-box .prompt { color: var(--sunat-red); }

			/* Stats */
			.stats {
				padding: 48px 24px;
				border-bottom: 1px solid var(--border);
			}
			.stats-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 0;
			}
			.stat {
				text-align: center;
				padding: 16px;
			}
			.stat:not(:last-child) { border-right: 1px solid var(--border); }
			.stat-value {
				font-size: 36px;
				font-weight: 700;
				color: var(--sunat-blue);
				line-height: 1;
			}
			.stat-label {
				font-size: 12px;
				color: var(--text-muted);
				margin-top: 4px;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			/* Features */
			.features { padding: 80px 24px; }
			.section-label {
				font-size: 12px;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--sunat-red);
				margin-bottom: 8px;
			}
			.section-title {
				font-size: 28px;
				font-weight: 700;
				color: var(--text-primary);
				margin-bottom: 40px;
				letter-spacing: -0.02em;
			}
			.features-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
				gap: 16px;
			}
			.feature-card {
				border: 1px solid var(--border);
				border-radius: 10px;
				padding: 24px;
				transition: border-color 200ms, box-shadow 200ms;
			}
			.feature-card:hover {
				border-color: var(--sunat-blue);
				box-shadow: 0 4px 12px rgba(26,53,103,0.08);
			}
			.feature-title {
				font-size: 16px;
				font-weight: 600;
				margin-bottom: 6px;
			}
			.feature-desc {
				font-size: 14px;
				color: var(--text-secondary);
				margin-bottom: 16px;
				line-height: 1.6;
			}
			.feature-code {
				background: var(--bg-dark);
				color: #94A3B8;
				padding: 8px 12px;
				border-radius: 6px;
				font-size: 11.5px;
				overflow-x: auto;
				white-space: nowrap;
			}

			/* Agent DX */
			.agent-dx {
				padding: 80px 24px;
				background: var(--sunat-blue);
				color: white;
			}
			.agent-dx .section-label { color: rgba(255,255,255,0.5); }
			.agent-dx .section-title { color: white; }
			.agent-dx-desc {
				color: rgba(255,255,255,0.7);
				max-width: 560px;
				font-size: 15px;
				line-height: 1.7;
				margin-bottom: 32px;
			}
			.principles {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
			}
			.principle {
				padding: 8px 16px;
				border: 1px solid rgba(255,255,255,0.2);
				border-radius: 6px;
				font-size: 13px;
				color: rgba(255,255,255,0.85);
				background: rgba(255,255,255,0.05);
			}

			/* Footer */
			footer {
				padding: 32px 24px;
				border-top: 1px solid var(--border);
				text-align: center;
				font-size: 13px;
				color: var(--text-muted);
			}
			footer a { color: var(--sunat-blue); text-decoration: none; }
			footer a:hover { text-decoration: underline; }

			@media (max-width: 640px) {
				.stats-grid { grid-template-columns: repeat(2, 1fr); }
				.stat:nth-child(2) { border-right: none; }
				.stat:nth-child(1), .stat:nth-child(2) { border-bottom: 1px solid var(--border); }
				.nav-links a:not(.nav-cta) { display: none; }
			}
		</style>
	</head>
	<body>
		<nav>
			<div class="nav-inner">
				<a href="#" class="nav-brand">sunat<span>/</span>cli</a>
				<div class="nav-links">
					<a href="#features">Features</a>
					<a href="#agent-dx">Agent DX</a>
					<a href="https://github.com/crafter-station/sunat-cli" class="nav-cta">GitHub</a>
				</div>
			</div>
		</nav>

		<section class="hero">
			<div class="container">
				<div class="hero-badge">
					<span class="dot"></span>
					<span class="mono">crafter station / gov-tech</span>
				</div>
				<h1>Automate SUNAT<br/>with <span class="accent">one CLI</span></h1>
				<p>
					Agent-first CLI for Peru's tax authority. Emit RHE, declare F616,
					verify via OAuth2 API. Built for AI agents as primary consumers.
				</p>
				<div class="hero-actions">
					<a href="https://github.com/crafter-station/sunat-cli" class="btn btn-primary">Get started</a>
					<a href="#features" class="btn btn-outline">Learn more</a>
				</div>
				<div class="install-box mono">
					<span class="prompt">$</span>
					<code>bun add @crafter/sunat-cli</code>
				</div>
			</div>
		</section>

		<section class="stats">
			<div class="container">
				<div class="stats-grid">
					{stats.map((s) => (
						<div class="stat">
							<div class="stat-value">{s.value}</div>
							<div class="stat-label">{s.label}</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="features" id="features">
			<div class="container">
				<p class="section-label mono">Capabilities</p>
				<h2 class="section-title">Everything SUNAT, one command</h2>
				<div class="features-grid">
					{features.map((f) => (
						<div class="feature-card">
							<h3 class="feature-title">{f.title}</h3>
							<p class="feature-desc">{f.desc}</p>
							<pre class="feature-code mono">{f.code}</pre>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="agent-dx" id="agent-dx">
			<div class="container">
				<p class="section-label mono">Design philosophy</p>
				<h2 class="section-title">Agent DX first</h2>
				<p class="agent-dx-desc">
					Following Justin Poehnelt's "Rewrite Your CLI for AI Agents" principles
					and the agentskills.io specification. The agent is not a trusted operator.
				</p>
				<div class="principles">
					{principles.map((p) => (
						<div class="principle mono">{p}</div>
					))}
				</div>
			</div>
		</section>

		<footer>
			<div class="container">
				<a href="https://crafterstation.com">Crafter Station</a> — Gov-Tech Research, Lima, Peru
			</div>
		</footer>
	</body>
</html>
